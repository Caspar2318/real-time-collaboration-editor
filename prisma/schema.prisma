generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  documents    Document[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Document {
  id        String   @id @default(cuid())
  title     String
  content   String   @default("")
  ownerId   String

  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}